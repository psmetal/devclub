{
  "routes": [
    {
      "src": "/api/comments",
      "dest": "/api/comments.js"
    },
    {
      "src": "/(.*)\\.html",
      "dest": "/$1.html"
    },
    {
      "src": "/assets/(.*)",
      "dest": "/assets/$1"
    },
    {
      "src": "/pages/(.*)",
      "dest": "/pages/$1"
    },
    {
      "src": "/scripts.js",
      "dest": "/scripts.js"
    },
    {
      "src": "/",
      "dest": "/index.html"
    }
  ]
}
